DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=8h
PORT=3001
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourapp.com

# Optional — Database pool tuning
# DB_POOL_MAX=20
# DB_POOL_IDLE_MS=30000
# DB_POOL_CONNECT_MS=10000
# DB_STATEMENT_TIMEOUT=30000

# Optional — Seed credentials (only used by db:init)
# SEED_SUPER_ADMIN_PASSWORD=RightWay@2026
# SEED_ADMIN_PASSWORD=Admin@2026
# SEED_COMMERCIAL_PASSWORD=Commercial@2026
